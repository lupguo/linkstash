# LinkStash Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Auth (required)
AUTH_SECRET_KEY=your-auth-secret
JWT_SECRET=your-jwt-secret

# Database (required if using MySQL)
MYSQL_PASSWORD=your-db-password

# LLM API Key (required for URL auto-analysis)
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# Alternative: OpenAI (uncomment and set, also update conf/app_dev.yaml)
# OPENAI_API_KEY=sk-your-openai-key
